<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Test Suite">
    <listeners>
        <listener
                class-name="com.api.listeners.TestListener"/>
    </listeners>
    <test name="API Tests" parallel="tests" thread-count="5">
        <classes>
            <class name="com.api.tests.CreateBookingTest"/>
            <class name="com.api.tests.GetBookingIdTest"/>
            <class name="com.api.tests.GetAllBookingIdsTest"/>
            <class name="com.api.tests.UpdateBookingTest"/>
            <class name="com.api.tests.PartialUpdateBookingTest"/>
            <class name="com.api.tests.DeleteBookingTest"/>
        </classes>
    </test>
</suite>
