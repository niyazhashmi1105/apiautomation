<suite name="Booking APIs Parallel Test Suite">
    <listeners>
        <listener class-name="com.api.listeners.TestListener"/>
    </listeners>

    <test name="Create Booking API" preserve-order="true">
        <classes>
            <class name="com.api.tests.CreateBookingTest"/>
        </classes>
    </test>

    <test name="Get Booking API"
          parallel="classes"
          thread-count="2"
          preserve-order="true">
        <classes>
            <class name="com.api.tests.GetBookingIdTest"/>
            <class name="com.api.tests.GetAllBookingIdsTest"/>
        </classes>
    </test>

    <test name="Update Booking API" preserve-order="true">
        <classes>
            <class name="com.api.tests.UpdateBookingTest"/>
        </classes>
    </test>

    <test name="Partial Update Booking API" preserve-order="true">
        <classes>
            <class name="com.api.tests.PartialUpdateBookingTest"/>
        </classes>
    </test>

    <test name="Delete Booking API" preserve-order="true">
        <classes>
            <class name="com.api.tests.DeleteBookingTest"/>
        </classes>
    </test>

</suite>